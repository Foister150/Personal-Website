{
    auto_https off
    admin off
    servers {
        trusted_proxies static private_ranges
    }
}

:80 {
    encode gzip zstd

    @blog host blog.landonfoister.com blog.landonfoister.localhost
    handle @blog {
        root * /srv/blog
        # Allow the static site (different subdomain) to fetch the blog feed.
        @feed path /feed.json /rss.xml /atom.xml
        header @feed Access-Control-Allow-Origin "*"
        try_files {path} {path}/ {path}.html =404
        file_server
    }

    handle {
        root * /srv/static
        try_files {path} {path}/ {path}.html =404
        file_server
    }
}
